# Copy this file to .env and set your machine's LAN IP so the app can
# reach the Docker backend from a physical device or Android/iOS emulator.
#
# On Windows: run `ipconfig` and look for "IPv4 Address" under your Wi-Fi adapter.
# On macOS/Linux: run `ifconfig` and look for inet under en0 or wlan0.
#
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8000
